// Plugin global Chart.js per labels A/B al LOS
Chart.register({
  id:'losLabels',
  afterDraw:function(chart){
    if(!chart.canvas.id||chart.canvas.id!=='elev-chart') return;
    var ctx=chart.ctx;
    // Buscar el dataset LOS (l'ultim amb dades de losHeights)
    var meta=null;for(var _mi=chart.data.datasets.length-1;_mi>=0;_mi--){var _m=chart.getDatasetMeta(_mi);if(_m&&_m.data&&_m.data.length>1){meta=_m;break;}}
    if(!meta||!meta.data||!meta.data.length) return;
    [0,meta.data.length-1].forEach(function(idx,li){
      var pt=meta.data[idx];if(!pt)return;
      var lbl=li===0?'A':'B';
      var col=li===0?'#ffff00':'#00e5ff';
      var y=Math.max(pt.y-14,14);
      ctx.save();
      ctx.font='bold 12px monospace';
      ctx.textAlign='center';
      ctx.fillStyle=col;
      ctx.fillText(lbl,pt.x,y);
      ctx.restore();
    });
  }
});
// Plugin global Fresnel el·liptic
window._fresnelEllipsePlugin = {
  id: 'fresnelEllipse',
  afterDatasetsDraw: function(chart) {
    var fd = window._fresnelDrawData;
    if(!fd||!fd.top||!fd.top.length) return;
    var ctx2=chart.ctx, xAxis=chart.scales.x, yAxis=chart.scales.y, n=fd.top.length;
    ctx2.save();
    ctx2.beginPath();
    ctx2.rect(chart.chartArea.left, chart.chartArea.top, chart.chartArea.right-chart.chartArea.left, chart.chartArea.bottom-chart.chartArea.top);
    ctx2.clip();

    function xpx(i){ return xAxis.getPixelForValue(i); }
    function ypx(v){ return yAxis.getPixelForValue(v); }

    // Area zona 1
    ctx2.beginPath(); ctx2.setLineDash([]); ctx2.fillStyle='rgba(144,238,144,0.08)';
    for(var i=0;i<n;i++) ctx2.lineTo(xpx(i), ypx(fd.top[i]));
    for(var i=n-1;i>=0;i--) ctx2.lineTo(xpx(i), ypx(fd.bot[i]));
    ctx2.closePath(); ctx2.fill();

    // Zona 1 (verd)
    ctx2.setLineDash([4,3]); ctx2.strokeStyle='rgba(144,238,144,0.9)'; ctx2.lineWidth=1.5;
    ctx2.beginPath();
    for(var i=0;i<n;i++){if(i===0)ctx2.moveTo(xpx(i),ypx(fd.top[i]));else ctx2.lineTo(xpx(i),ypx(fd.top[i]));}
    ctx2.stroke();
    ctx2.beginPath();
    for(var i=0;i<n;i++){if(i===0)ctx2.moveTo(xpx(i),ypx(fd.bot[i]));else ctx2.lineTo(xpx(i),ypx(fd.bot[i]));}
    ctx2.stroke();

    // Zona 2 (taronja)
    ctx2.setLineDash([3,5]); ctx2.strokeStyle='rgba(255,165,0,0.65)'; ctx2.lineWidth=1.3;
    ctx2.beginPath();
    for(var i=0;i<n;i++){if(i===0)ctx2.moveTo(xpx(i),ypx(fd.top2[i]));else ctx2.lineTo(xpx(i),ypx(fd.top2[i]));}
    ctx2.stroke();
    ctx2.beginPath();
    for(var i=0;i<n;i++){if(i===0)ctx2.moveTo(xpx(i),ypx(fd.bot2[i]));else ctx2.lineTo(xpx(i),ypx(fd.bot2[i]));}
    ctx2.stroke();

    // Zona 3 (blau)
    ctx2.setLineDash([2,6]); ctx2.strokeStyle='rgba(100,180,255,0.45)'; ctx2.lineWidth=1.1;
    ctx2.beginPath();
    for(var i=0;i<n;i++){if(i===0)ctx2.moveTo(xpx(i),ypx(fd.top3[i]));else ctx2.lineTo(xpx(i),ypx(fd.top3[i]));}
    ctx2.stroke();
    ctx2.beginPath();
    for(var i=0;i<n;i++){if(i===0)ctx2.moveTo(xpx(i),ypx(fd.bot3[i]));else ctx2.lineTo(xpx(i),ypx(fd.bot3[i]));}
    ctx2.stroke();

    ctx2.restore();
  }
};
