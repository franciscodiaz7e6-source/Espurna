function goToCoords(){
  var lat=parseFloat(document.getElementById('coord-lat').value.replace(',','.'));
  var lng=parseFloat(document.getElementById('coord-lng').value.replace(',','.'));
  if(isNaN(lat)||isNaN(lng)){
    alert('Coordenades no vàlides');return;
  }
  map.setView([lat,lng],16);
  // Marcador temporal amb cercle
  if(window._coordMarker){map.removeLayer(window._coordMarker);map.removeLayer(window._coordCircle);}
  window._coordMarker=L.circleMarker([lat,lng],{
    radius:8,color:'#00e5ff',fillColor:'#00e5ff',fillOpacity:0.9,weight:2
  }).addTo(map).bindPopup('<b>🎯 '+lat.toFixed(5)+', '+lng.toFixed(5)+'</b>').openPopup();
  window._coordCircle=L.circle([lat,lng],{
    radius:100,color:'#00e5ff',fillColor:'#00e5ff',fillOpacity:0.08,weight:1,dashArray:'5,5'
  }).addTo(map);
  document.getElementById('coords-panel').remove();
  // Si venim de Posar Nodes, restaurar hint
  if(window._pnCoordsMode&&pnMode){
    window._pnCoordsMode=false;
    var hint=document.getElementById('los-hint');
    if(hint){hint.textContent='📍 Obre el menú ⋮ per seleccionar tipus';hint.style.display='block';}
  } else {
    window._pnCoordsMode=false;
  }
}

// ── POSAR NODES ─────────────────────────────────────────────
var pnMode=false;
var pnCurrentType=null;
var pnMenuOpen=false;
var pnItems=[];
var pnItems3D=[];
var pnMarkers=[];

function togglePNMenu(){
  pnMenuOpen=!pnMenuOpen;
  document.getElementById('pn-dots-menu').classList.toggle('open',pnMenuOpen);
}

function hmPosar(){
  if(typeof closeHMenu==='function') closeHMenu();
  var wasPN=pnMode;
  window._pnActivating=true;
  // Tancar altres eines sense bucle
  if(losMode){losMode=false;losPoints=[];var _hl=document.getElementById('hm-los');if(_hl)_hl.classList.remove('active');var _lw=document.getElementById('los-dots-wrap');if(_lw)_lw.style.display='none';showLeafletZoom();}
  if(covMode){covMode=false;var _hc=document.getElementById('hm-cov');if(_hc)_hc.classList.remove('active');var _rw=document.getElementById('rf-dots-wrap');if(_rw)_rw.style.display='none';showLeafletZoom();}
  if(windVisible){
    windVisible=false;
    if(window._cesiumWindInterval){clearInterval(window._cesiumWindInterval);window._cesiumWindInterval=null;}
    if(window._cesiumWindEntities){window._cesiumWindEntities.forEach(function(e){try{cesiumViewer.entities.remove(e);}catch(ex){}});window._cesiumWindEntities=[];}
    if(typeof windLayer!=='undefined'&&windLayer){try{map.removeLayer(windLayer);}catch(e){}windLayer=null;}
    var wb=document.getElementById('hm-wind-btn');if(wb)wb.classList.remove('active');
    var wleg=document.getElementById('wind-legend');if(wleg)wleg.remove();
  }
  if(ndviVisible){if(typeof closeNDVIPanel==='function')closeNDVIPanel();}
  if(typeof closePowerPanel==='function')closePowerPanel();
  if(typeof closeAQPanel==='function')closeAQPanel();
  if(typeof closeAemetPanel==='function')closeAemetPanel();
  if(typeof closeEonetPanel==='function')closeEonetPanel();
  if(typeof closeFirmsPanel==='function')closeFirmsPanel();
  if(typeof closeBurnedPanel==='function')closeBurnedPanel();
  // Treure fons verd de totes les eines
  ['hm-firms-btn','hm-ndvi-btn','hm-eonet-btn','hm-aq-btn','hm-aemet-btn','hm-meteo-btn','hm-wind-btn','hm-power-btn','hm-burned-btn'].forEach(function(id){var el=document.getElementById(id);if(el)el.classList.remove('active');});
  window._pnActivating=false;
  if(wasPN){
    // Desactivar
    pnMode=false;
    pnCurrentType=null;
    var hw=document.getElementById('hm-posar');if(hw){hw.classList.remove('active');hw.classList.remove('act-green');}
    var pw=document.getElementById('pn-dots-wrap');if(pw)pw.style.display='none';
    var pp=document.getElementById('pn-panel');if(pp)pp.style.display='none';
    pnMenuOpen=false;var _pm=document.getElementById('pn-dots-menu');if(_pm)_pm.classList.remove('open');
    showLeafletZoom();
    var hint=document.getElementById('los-hint');if(hint)hint.style.display='none';
    if(!is3D){map.getContainer().style.cursor='';map.getContainer().classList.remove('waiting-click');document.body.classList.remove('waiting-click');}
    if(cesiumViewer)cesiumViewer.canvas.style.cursor='';
    return;
  }
  // Activar
  pnMode=true;
  var hw=document.getElementById('hm-posar');if(hw){hw.classList.add('active');hw.classList.add('act-green');}
  var pw=document.getElementById('pn-dots-wrap');if(pw)pw.style.display='block';
  var pp=document.getElementById('pn-panel');
  if(pp){pp.style.display='block';pnRenderPanel();}
  hideLeafletZoom();
  var hint=document.getElementById('los-hint');
  if(hint){hint.textContent='📍 Obre el menú ⋮ per seleccionar tipus';hint.style.display='block';}
  // Amagar los-dots-wrap i rf-dots-wrap
  var _lw=document.getElementById('los-dots-wrap');if(_lw&&!losMode)_lw.style.display='none';
  var _rw=document.getElementById('rf-dots-wrap');if(_rw&&!covMode)_rw.style.display='none';
  pnRenderPanel();
}

function pnSetMode(type){
  pnCurrentType=type;
  pnMenuOpen=false;
  document.getElementById('pn-dots-menu').classList.remove('open');
  var labels={gateway:'Gateway',sensor:'Node Sensor',torre:'Torre'};
  var icons={gateway:'📡',sensor:'🌡',torre:'🗼'};
  var hint=document.getElementById('los-hint');
  if(hint){hint.textContent=icons[type]+' Clica al mapa per posar '+labels[type];hint.style.display='block';}
