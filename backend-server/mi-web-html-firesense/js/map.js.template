  body.innerHTML='<div style="color:rgba(255,68,68,.5);font-size:10px;">Carregant...</div>';
  panel.style.display='block';
  fetch('/nasa-eonet')
    .then(function(r){return r.json();})
    .then(function(events){
      var html='<div style="color:#ff4444;font-size:10px;font-weight:bold;margin-bottom:10px;letter-spacing:.08em;">'+events.length+' INCENDIS · BARCELONA · ANY EN CURS</div>';
      if(events.length===0){
        html+='<div style="color:rgba(255,255,255,.5);font-size:10px;">Cap incendi registrat a la zona</div>';
      }
      var gencatMarkers=window._gencatMarkers||[];
      gencatMarkers.forEach(function(m){try{map.removeLayer(m);}catch(e){}});
      window._gencatMarkers=[];
      if(window._cesiumGencatEntities){window._cesiumGencatEntities.forEach(function(e){try{cesiumViewer.entities.remove(e);}catch(ex){}});window._cesiumGencatEntities=[];}
      events.forEach(function(ev){
        var date=ev.data_incendi?ev.data_incendi.slice(0,10):'—';
        var dd=date.slice(8,10)+'/'+date.slice(5,7)+'/'+date.slice(0,4);
        var haTotal=(parseFloat(ev.haforestal)||0).toFixed(2);
        var haArb=(parseFloat(ev.haarbrades)||0).toFixed(2);
        html+='<div style="border:1px solid rgba(255,68,68,.2);border-radius:4px;padding:8px;margin-bottom:6px;background:rgba(255,50,0,.04);">'+
          '<div style="color:#ff6b6b;font-size:10px;font-weight:bold;margin-bottom:4px;">🔥 '+ev.termemunic+' · '+ev.comarca+'</div>'+
          '<div style="color:rgba(255,255,255,.75);font-size:10px;">📅 '+dd+'</div>'+
          '<div style="color:rgba(255,255,255,.75);font-size:10px;margin-top:3px;">🌲 Forestal: <b>'+haTotal+' ha</b> · Arbrada: '+haArb+' ha</div>'+
          '</div>';
        // Geocodificar municipi amb Nominatim
        (function(ev, dd, haTotal){
          fetch('https://nominatim.openstreetmap.org/search?q='+encodeURIComponent(ev.termemunic+', Catalunya')+'&format=json&limit=1')
            .then(function(r){return r.json();})
            .then(function(res){
              if(!res||!res[0]) return;
              var lat=parseFloat(res[0].lat), lng=parseFloat(res[0].lon);
              var ha=parseFloat(haTotal);
              var color=ha>1?'#ff1744':ha>0.1?'#ff9800':'#ffeb3b';
              var r=ha>1?14:ha>0.1?10:7;
              if(is3D && cesiumViewer){
                if(!window._cesiumGencatEntities) window._cesiumGencatEntities=[];
                var cesCol=Cesium.Color.fromCssColorString(color);
                var sz=ha>1?22:ha>0.1?16:11;
                var ent=cesiumViewer.entities.add({
                  position:Cesium.Cartesian3.fromDegrees(lng,lat,30),
                  point:{pixelSize:sz,color:cesCol.withAlpha(0.85),outlineColor:Cesium.Color.WHITE,outlineWidth:1,heightReference:Cesium.HeightReference.CLAMP_TO_GROUND},
                  description:'<b>🔥 '+ev.termemunic+'</b><br>'+ev.comarca+'<br>📅 '+dd+'<br>🌲 '+haTotal+' ha'
                });
                window._cesiumGencatEntities.push(ent);
              } else {
                var m=L.circleMarker([lat,lng],{
                  radius:r,color:color,fillColor:color,fillOpacity:0.7,weight:2
                }).bindPopup(
                  '<b>🔥 '+ev.termemunic+'</b><br>'+
                  ev.comarca+'<br>'+
                  '📅 '+dd+'<br>'+
                  '🌲 '+haTotal+' ha forestals'
                ).addTo(map);
                window._gencatMarkers.push(m);
              }
            });
        })(ev, dd, haTotal);
      });
      body.innerHTML=html;
    })
    .catch(function(){body.innerHTML='<div style="color:#ff4444;font-size:10px;">Error carregant dades</div>';});
}

// ── NASA NDVI Layer (GIBS WMS) ───────────────────────────────
var ndviLayer = null;
var ndviVisible = false;

function closeNDVIPanel(){
  document.getElementById('ndvi-panel').style.display='none';
  if(ndviLayer){try{map.removeLayer(ndviLayer);}catch(e){}ndviLayer=null;}
  if(window._cesiumNdviLayer){try{cesiumViewer.imageryLayers.remove(window._cesiumNdviLayer,false);}catch(e){}window._cesiumNdviLayer=null;}
  if(window._cesiumRiscLayer){try{cesiumViewer.imageryLayers.remove(window._cesiumRiscLayer,false);}catch(e){}window._cesiumRiscLayer=null;}
  if(window._cesiumNdviPrimitives){window._cesiumNdviPrimitives.forEach(function(p){try{cesiumViewer.scene.primitives.remove(p);}catch(e){}});window._cesiumNdviPrimitives=[];}
  ndviVisible=false;
  var btn=document.getElementById('hm-ndvi-btn');
  if(btn) btn.classList.remove('active');
}

function toggleNDVI(){
  if(typeof closeHMenu==="function") closeHMenu();
  var was=ndviVisible;
  closeAllTools();
  if(was){return;}
  var d=new Date();d.setDate(d.getDate()-8);
  var dateStr=d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');
  if(!is3D){
    ndviLayer=L.layerGroup([
      L.tileLayer.wms('https://gibs.earthdata.nasa.gov/wms/epsg3857/best/wms.cgi',{
        layers:'VIIRS_SNPP_NDVI_8Day',format:'image/png',transparent:true,
        version:'1.3.0',time:dateStr,opacity:0.35,attribution:'NASA GIBS · VIIRS NDVI 8-Day'
      }),
      L.tileLayer.wms('https://pcivil.icgc.cat/ogc/geoservei?map=/opt/idec/dades/pcivil/risc_incendis.map',{
        layers:'infocat_perill',format:'image/png',transparent:true,
        version:'1.1.1',opacity:0.65,attribution:'Protecció Civil Catalunya · Perill Incendi'
      })
    ]).addTo(map);
  }
  ndviVisible=true;
  var btn=document.getElementById('hm-ndvi-btn');
  if(btn) btn.classList.add('active');
  var panel=document.getElementById('ndvi-panel');
  var body=document.getElementById('ndvi-panel-body');
  body.innerHTML='<div style="color:rgba(0,255,100,.5);font-size:10px;">Calculant NDVI...</div>';
  panel.style.display='block';
  if(is3D && cesiumViewer){
    body.innerHTML='<div style="color:rgba(0,255,100,.5);font-size:10px;">Carregant NDVI regional...</div>';
    Promise.all([
      fetch('/nasa-ndvi-regional').then(function(r){return r.json();}).catch(function(){return null;}),
      fetch('/nasa-ndvi?lat=41.45&lng=2.18').then(function(r){return r.json();})
    ]).then(function(results){
      var regional=results[0], panelData=results[1];
      if(regional&&regional.subset&&regional.subset[0]&&regional.subset[0].data){
        var subset=regional.subset[0];
        var nr=regional.nrows,nc=regional.ncols,cellM=regional.cellsize;
        var halfH=nr*cellM/2/111320,halfW=nc*cellM/2/82600;
        var west0=2.18-halfW,east0=2.18+halfW,south0=41.45-halfH,north0=41.45+halfH;
        if(window._cesiumNdviPrimitives){window._cesiumNdviPrimitives.forEach(function(p){try{cesiumViewer.scene.primitives.remove(p);}catch(e){}});window._cesiumNdviPrimitives=[];}
        if(window._cesiumNdviLayer){try{cesiumViewer.imageryLayers.remove(window._cesiumNdviLayer,false);}catch(e){}window._cesiumNdviLayer=null;}
        window._cesiumNdviPrimitives=[];
        var colMap2={
          sec:Cesium.Color.fromCssColorString('#dc3214').withAlpha(0.65),
          mod:Cesium.Color.fromCssColorString('#ff8c00').withAlpha(0.65),
          acc:Cesium.Color.fromCssColorString('#ffe600').withAlpha(0.6),
          sa:Cesium.Color.fromCssColorString('#00b432').withAlpha(0.6)
        };
        var cellW2=(east0-west0)/nc,cellH2=(north0-south0)/nr;
        var buckets2={sec:[],mod:[],acc:[],sa:[]};
        subset.data.forEach(function(v,i){
          var vn=v/10000; if(vn<0) return;
          var ix2=i%nc,iy2=Math.floor(i/nc);
          var w2=west0+ix2*cellW2,e2=w2+cellW2,n2=north0-iy2*cellH2,s2=n2-cellH2;
          var k=vn<0.2?'sec':vn<0.35?'mod':vn<0.5?'acc':'sa';
          buckets2[k].push(new Cesium.GeometryInstance({
            geometry:new Cesium.RectangleGeometry({rectangle:Cesium.Rectangle.fromDegrees(w2,s2,e2,n2)}),
            attributes:{color:Cesium.ColorGeometryInstanceAttribute.fromColor(colMap2[k])}
          }));
        });
        Object.keys(buckets2).forEach(function(k){
          if(!buckets2[k].length) return;
          var prim=new Cesium.GroundPrimitive({
            geometryInstances:buckets2[k],
            appearance:new Cesium.PerInstanceColorAppearance({flat:true,translucent:true}),
            classificationType:Cesium.ClassificationType.CESIUM_3D_TILE
          });
          cesiumViewer.scene.primitives.add(prim);
          window._cesiumNdviPrimitives.push(prim);
        });
      }
      // Panel complet igual que 2D
      var ndviRaw=null,date='--';
      (panelData.subset||[]).forEach(function(s){if(s.band==='250m_16_days_NDVI'&&s.data[0]>-2000){ndviRaw=s.data[0]/10000;date=s.calendar_date;}});
      if(ndviRaw!==null){
        var eviRaw=null,nirRaw=null,redRaw=null,blueRaw=null,quality=null;
        (panelData.subset||[]).forEach(function(s){
          if(s.band==='250m_16_days_EVI') eviRaw=s.data[0]/10000;
          if(s.band==='250m_16_days_NIR_reflectance') nirRaw=s.data[0]/10000;
          if(s.band==='250m_16_days_red_reflectance') redRaw=s.data[0]/10000;
          if(s.band==='250m_16_days_blue_reflectance') blueRaw=s.data[0]/10000;
          if(s.band==='250m_16_days_pixel_reliability') quality=s.data[0];
        });
        var ndwi=nirRaw&&blueRaw?(blueRaw-nirRaw)/(blueRaw+nirRaw):null;
        var riskScore=0;
        if(ndviRaw<0.2) riskScore+=3; else if(ndviRaw<0.35) riskScore+=2; else if(ndviRaw<0.5) riskScore+=1;
        if(eviRaw&&eviRaw<0.15) riskScore+=2; else if(eviRaw&&eviRaw<0.25) riskScore+=1;
        if(ndwi&&ndwi>0) riskScore+=1;
        var risk=riskScore>=4?'ALT':riskScore>=2?'MODERAT':'BAIX';
        var riskColor=riskScore>=4?'#ff1744':riskScore>=2?'#ff9800':'#00ff88';
        var riskIcon=riskScore>=4?'🔴':riskScore>=2?'🟠':'🟢';
        var qualityTxt=quality===0?'Excel·lent':quality===1?'Bona':quality===2?'Marginal (núvols)':'No fiable';
        var qualityColor=quality===0?'#00ff88':quality===1?'#ffeb3b':quality===2?'#ff9800':'#ff1744';
        var barW=Math.min(100,Math.round(ndviRaw*100));
