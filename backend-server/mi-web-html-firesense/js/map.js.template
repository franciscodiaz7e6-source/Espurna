    map.getContainer().style.cursor='crosshair';
    map.getContainer().classList.add('waiting-click');
    document.body.classList.add('waiting-click');
  } else if(cesiumViewer){
    cesiumViewer.canvas.style.cursor='crosshair';
  }
}

var _pnPending=null;
var _pnPendingIs3D=false;
var _pnTech='lorawan';

function pnSelectTech(tech){
  _pnTech=tech;
  var bl=document.getElementById('pn-tech-lorawan');
  var bm=document.getElementById('pn-tech-meshcore');
  if(tech==='lorawan'){
