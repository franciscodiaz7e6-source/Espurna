// ── NASA MODIS Burned Area ───────────────────────────────────
var burnedMarkers = [];
var burnedVisible = false;

function closeBurnedPanel(){
  document.getElementById('burned-panel').style.display='none';
  burnedMarkers.forEach(function(m){map.removeLayer(m);});
  burnedMarkers=[];
  burnedVisible=false;
  var btn=document.getElementById('hm-burned-btn');
  if(btn) btn.classList.remove('active');
}

function toggleBurnedArea(){
  if(typeof closeHMenu==="function") closeHMenu();
  var was=burnedVisible;
  closeAllTools();
  if(was){return;}
  var btn=document.getElementById('hm-burned-btn');
  if(btn) btn.classList.add('active');
  burnedVisible=true;
  var panel=document.getElementById('burned-panel');
  var body=document.getElementById('burned-panel-body');
  body.innerHTML='<div style="color:rgba(255,68,68,.5);font-size:10px;">Carregant zones cremades...</div>';
  panel.style.display='block';
  fetch('/nasa-burned?lat=41.45&lng=2.18')
    .then(function(r){return r.json();})
    .then(function(d){
      var subset=d.subset||[];
      var xll=parseFloat(d.xllcorner),yll=parseFloat(d.yllcorner);
      var cs=parseFloat(d.cellsize),ncols=d.ncols,nrows=d.nrows;
      var burned=[];
      subset.forEach(function(s){
        if(s.band!=='Burn_Date') return;
        s.data.forEach(function(v,idx){
          if(v>0){
            var col=idx%ncols, row=Math.floor(idx/ncols);
            var x=xll+col*cs+cs/2, y=yll+(nrows-row-1)*cs+cs/2;
            // Convertir UTM a lat/lng aproximat (zona 31N)
            var lat=y/111320;
            var lng=x/(111320*Math.cos(lat*Math.PI/180));
            burned.push({lat:lat,lng:lng,day:v,date:s.calendar_date});
          }
        });
      });
      if(burned.length===0){
        body.innerHTML='<div style="color:rgba(255,255,255,.5);font-size:10px;">Cap zona cremada detectada a Collserola i voltants durant el periode analitzat.</div>';
        return;
      }
      burned.forEach(function(b){
        var m=L.circleMarker([b.lat,b.lng],{
          radius:10,color:'#ff1744',fillColor:'#ff4444',
          fillOpacity:0.6,weight:2
        }).bindPopup(
          '<b>🔴 Zona Cremada</b><br>'+
          'Data deteccio: '+b.date+'<br>'+
          'Dia de l\'any: '+b.day
        ).addTo(map);
        burnedMarkers.push(m);
      });
      var year=new Date().getFullYear()-1;
      body.innerHTML='<div style="color:#ff4444;font-size:10px;font-weight:bold;margin-bottom:10px;">'+burned.length+' ZONES CREMADES · COLLSEROLA · '+year+'</div>'+
        burned.map(function(b){
          return '<div style="border:1px solid rgba(255,68,68,.2);border-radius:4px;padding:8px;margin-bottom:6px;background:rgba(255,50,0,.04);">'+
            '<div style="color:#ff6b6b;font-size:10px;font-weight:bold;">🔴 Zona cremada</div>'+
            '<div style="color:rgba(255,255,255,.75);font-size:10px;">📅 '+b.date+'</div>'+
            '<div style="color:rgba(255,255,255,.5);font-size:9px;">Dia any: '+b.day+'</div>'+
            '</div>';
        }).join('');
    })
    .catch(function(){body.innerHTML='<div style="color:#ff4444;font-size:10px;">Error carregant dades</div>';});
}

