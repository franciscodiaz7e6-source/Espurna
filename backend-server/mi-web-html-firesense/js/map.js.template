// ── CESIUM CLICK HANDLER ──────────────────────────────────────
var losMode=false,covMode=false,losPoints=[],losPrimitives=[];
var _bldCache={};
var losEntityA=null,losEntityB=null,losEntityLine=null;
var waitingForClick=false;

function initCesiumClickHandler(){

  var handler=new Cesium.ScreenSpaceEventHandler(cesiumViewer.canvas);
  handler.setInputAction(function(click){

    if(!losMode&&!covMode&&!pnMode)return;
    if(pnMode&&pnCurrentType){
      var _pos2=cesiumViewer.scene.pickPosition(click.position);
      if(_pos2&&Cesium.defined(_pos2)){var _c2=Cesium.Cartographic.fromCartesian(_pos2);pnShowModal(Cesium.Math.toDegrees(_c2.latitude),Cesium.Math.toDegrees(_c2.longitude),pnCurrentType);}
      return;
    }
    if(losMode&&!waitingForClick)return;
    if(pnMode&&pnCurrentType){
      var _pos2=cesiumViewer.scene.pickPosition(click.position);
      if(_pos2&&Cesium.defined(_pos2)){var _c2=Cesium.Cartographic.fromCartesian(_pos2);pnShowModal(Cesium.Math.toDegrees(_c2.latitude),Cesium.Math.toDegrees(_c2.longitude),pnCurrentType);}
      return;
    }
    if(covMode&&!waitingForClick)return;
    // Usar scene.pickPosition per funcionar amb Google Photorealistic (globe.show=false)
    var pos=cesiumViewer.scene.pickPosition(click.position);
    if(!pos||!Cesium.defined(pos))return;
    if(covMode){
      // Convertir posicio Cesium a lat/lng i fer el mateix que en 2D
      var carto=Cesium.Cartographic.fromCartesian(pos);
      var lat=Cesium.Math.toDegrees(carto.latitude);
      var lng=Cesium.Math.toDegrees(carto.longitude);
      var elev=carto.height||0;
      var params=rfGetParams();
      var node=RFMulti.addNode(lat,lng,elev,params);
      RFMulti.calculate(node, is3D ? cesiumViewer : null);
      // Despres del click, esperar nou "+ AFEGIR NODE" igual que en 2D
      waitingForClick=false;
      cesiumViewer.canvas.style.cursor='default';
      var hint=document.getElementById('los-hint');
      if(hint){hint.textContent='📡 Calculant cobertura...';RFMulti.calculate(node, is3D ? cesiumViewer : null).then(function(){if(hint){hint.textContent='✅ Node '+node.label+' afegit. Prem "+ AFEGIR NODE" per afegir-ne un altre.';setTimeout(function(){if(hint)hint.style.display='none';},3000);}});}
      return;
    }
    if(losMode){
      if(losPoints.length===0){
        if(losEntityA){try{cesiumViewer.entities.remove(losEntityA);}catch(e){} losEntityA=null;}
        losEntityA=cesiumViewer.entities.add({position:pos,point:{pixelSize:12,color:Cesium.Color.YELLOW,outlineColor:Cesium.Color.WHITE,outlineWidth:2},label:{text:"A",font:"bold 12px Share Tech Mono",fillColor:Cesium.Color.YELLOW,outlineColor:Cesium.Color.BLACK,outlineWidth:2,style:Cesium.LabelStyle.FILL_AND_OUTLINE,pixelOffset:new Cesium.Cartesian2(0,-22),heightReference:Cesium.HeightReference.NONE}});
        losPoints.push(pos);
        waitingForClick=false;
        cesiumViewer.canvas.style.cursor="default";
        document.getElementById("los-hint").textContent="Punt A posat. Obre menu per afegir punt B";
      } else if(losPoints.length===1){
        if(losEntityB){try{cesiumViewer.entities.remove(losEntityB);}catch(e){} losEntityB=null;}
        if(losEntityLine){try{cesiumViewer.entities.remove(losEntityLine);}catch(e){} losEntityLine=null;}
        var p1=losPoints[0],p2=pos;
        losEntityB=cesiumViewer.entities.add({position:p2,point:{pixelSize:12,color:Cesium.Color.CYAN,outlineColor:Cesium.Color.WHITE,outlineWidth:2},label:{text:"B",font:"bold 12px Share Tech Mono",fillColor:Cesium.Color.CYAN,outlineColor:Cesium.Color.BLACK,outlineWidth:2,style:Cesium.LabelStyle.FILL_AND_OUTLINE,pixelOffset:new Cesium.Cartesian2(0,-22),heightReference:Cesium.HeightReference.NONE}});
        losEntityLine=cesiumViewer.entities.add({polyline:{positions:[p1,p2],width:2,material:new Cesium.ColorMaterialProperty(Cesium.Color.LIME.withAlpha(0.7)),arcType:Cesium.ArcType.NONE}});
        // Fresnel zones en Cesium 3D
        var _fN=20,_fLam=0.3/869;
        var _cA=Cesium.Cartographic.fromCartesian(p1),_cB=Cesium.Cartographic.fromCartesian(p2);
        var _fPtsTop=[],_fPtsBot=[];
        for(var _fi=0;_fi<=_fN;_fi++){
          var _ff=_fi/_fN;
          var _fLat=Cesium.Math.toDegrees(_cA.latitude)+(_cB.latitude-_cA.latitude)*_ff*180/Math.PI;
          var _fLng=Cesium.Math.toDegrees(_cA.longitude)+(_cB.longitude-_cA.longitude)*_ff*180/Math.PI;
          var _fH=_cA.height+(_cB.height-_cA.height)*_ff;
          var _fd1=_ff*300,_fd2=(1-_ff)*300;
          var _fR=(_fd1>0&&_fd2>0)?Math.sqrt(_fLam*_fd1*_fd2/(_fd1+_fd2)):0;
          _fPtsTop.push(Cesium.Cartesian3.fromDegrees(_fLng,_fLat,_fH+_fR*2));
          _fPtsBot.push(Cesium.Cartesian3.fromDegrees(_fLng,_fLat,_fH-_fR*2));
        }
        losPrimitives.push(cesiumViewer.entities.add({polyline:{positions:_fPtsTop,width:1,material:new Cesium.PolylineDashMaterialProperty({color:Cesium.Color.CYAN.withAlpha(0.5),dashLength:12}),arcType:Cesium.ArcType.NONE}}));
        losPrimitives.push(cesiumViewer.entities.add({polyline:{positions:_fPtsBot,width:1,material:new Cesium.PolylineDashMaterialProperty({color:Cesium.Color.CYAN.withAlpha(0.5),dashLength:12}),arcType:Cesium.ArcType.NONE}}));
        losPoints.push(p2);
        waitingForClick=false;
        cesiumViewer.canvas.style.cursor="default";
        runElevationProfile(p1,p2);
      }
    }
  },Cesium.ScreenSpaceEventType.LEFT_CLICK);
}
