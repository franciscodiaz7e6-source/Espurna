  fetch('/open-aq?lat=41.45&lng=2.18')
    .then(function(r){return r.json();})
    .then(function(d){
      var results=d.results||[];
      // Límits OMS per qualitat aire
      var limits={no2:40,so2:20,pm25:15,pm10:45,o3:100,co:4000};
      var paramNames={no2:'NO₂',so2:'SO₂',pm25:'PM2.5',pm10:'PM10',o3:'O₃',co:'CO',no:'NO',nox:'NOx'};
      var paramUnits={no2:'µg/m³',so2:'µg/m³',pm25:'µg/m³',pm10:'µg/m³',o3:'µg/m³',co:'µg/m³',no:'µg/m³',nox:'µg/m³'};
      var html='<div style="color:rgba(0,229,255,.5);font-size:9px;margin-bottom:10px;letter-spacing:.08em;font-weight:bold;">'+results.length+' ESTACIONS · RADI 25KM</div>';
      results.forEach(function(s){
        var readings=s.readings||[];
        if(!readings.length) return;
        var maxDate=readings.reduce(function(a,b){return a.date>b.date?a:b;},{date:''}).date;
        var dateStr=maxDate?maxDate.slice(0,16).replace('T',' ')+'h':'—';
        html+='<div style="border:1px solid rgba(0,229,255,.15);border-radius:4px;padding:8px;margin-bottom:8px;background:rgba(0,180,255,.03);">'+
