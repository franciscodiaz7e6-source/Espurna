function getBuildingHeight(la,ln){
  var key=la.toFixed(4)+","+ln.toFixed(4);
  if(_bldCache[key]!==undefined) return Promise.resolve(_bldCache[key]);
  var q="[out:json][timeout:25];way(around:200,"+la+","+ln+")[\"height\"];out tags;";
  var ctrl=new AbortController();
  var tid=setTimeout(function(){ctrl.abort();},25000);
  return fetch("https://overpass.kumi.systems/api/interpreter?data="+encodeURIComponent(q),{signal:ctrl.signal})
    .then(function(r){clearTimeout(tid);return r.json();})
    .then(function(d){
      for(var i=0;i<d.elements.length;i++){
        var h=parseFloat(d.elements[i].tags&&d.elements[i].tags.height);
        if(h>0){_bldCache[key]=h;return h;}
      }
      _bldCache[key]=2;return 2;
    }).catch(function(){_bldCache[key]=2;return 2;});
}
