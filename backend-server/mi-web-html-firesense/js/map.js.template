function loadFirmsLayer() {
  var bbox = '1.5,41.2,2.5,41.7';
  var days = 1;
  fetch('/firms/active?bbox=' + bbox + '&days=' + days)
    .then(function(r) { return r.text(); })
    .then(function(csv) {
      if (firmsLayer) map.removeLayer(firmsLayer);
      firmsLayer = L.layerGroup();
      var lines = csv.trim().split('\n');
      for (var i = 1; i < lines.length; i++) {
        var cols = lines[i].split(',');
        if (cols.length < 2) continue;
        var lat = parseFloat(cols[0]);
        var lng = parseFloat(cols[1]);
        var conf = cols[9] || 'n';
        var color = conf === 'h' ? '#ff1744' : conf === 'n' ? '#ff9800' : '#ffeb3b';
        L.circleMarker([lat, lng], {
          radius: 8, color: color, fillColor: color,
          fillOpacity: 0.8, weight: 1
        }).bindPopup(
          '<b>🔥 Punt de calor NASA</b><br>' +
          'Data: ' + cols[5] + ' ' + cols[6] + '<br>' +
          'Confiança: ' + conf + '<br>' +
          'FRP: ' + cols[12] + ' MW'
        ).addTo(firmsLayer);
      }
      if(is3D && cesiumViewer){
        cesiumFirmsEntities.forEach(function(e){try{cesiumViewer.entities.remove(e);}catch(ex){}});
        cesiumFirmsEntities=[];
        for(var j=1;j<lines.length;j++){
          var c2=lines[j].split(',');if(c2.length<2)continue;
          var la=parseFloat(c2[0]),ln=parseFloat(c2[1]);
          var cf=c2[9]||'n';
          var col=cf==='h'?Cesium.Color.fromCssColorString('#ff1744'):cf==='n'?Cesium.Color.fromCssColorString('#ff9800'):Cesium.Color.fromCssColorString('#ffeb3b');
          var ent=cesiumViewer.entities.add({
            position:Cesium.Cartesian3.fromDegrees(ln,la,50),
            point:{pixelSize:20,color:col,outlineColor:Cesium.Color.WHITE,outlineWidth:2,heightReference:Cesium.HeightReference.CLAMP_TO_GROUND},
            description:'<b>🔥 Punt de calor NASA</b><br>Confiança: '+cf+'<br>FRP: '+c2[12]+' MW'
          });
          cesiumFirmsEntities.push(ent);
        }
      } else {
        firmsLayer.addTo(map);
      }
      firmsVisible = true;
      var btn=document.getElementById('hm-firms-btn');
      if(btn) btn.classList.add('active');
      // Mostrar panel
      var body=document.getElementById('firms-panel-body');
      var panel=document.getElementById('firms-panel');
      if(body && lines.length>1){
        var now=new Date();var dd=String(now.getDate()).padStart(2,'0');var mm=String(now.getMonth()+1).padStart(2,'0');var yyyy=now.getFullYear();
        var html='<div style="color:#ff1744;font-size:10px;margin-bottom:8px;letter-spacing:.08em;font-weight:bold;">'+
          (lines.length-1)+' DETECCIONS · VIIRS SNPP · '+dd+'/'+mm+'/'+yyyy+'</div>';
        for(var j=1;j<lines.length;j++){
          var c=lines[j].split(',');
          if(c.length<13) continue;
          var conf=c[9]==='h'?'ALTA':c[9]==='n'?'NOMINAL':'BAIXA';
          var confColor=c[9]==='h'?'#ff1744':c[9]==='n'?'#ff9800':'#ffeb3b';
          html+='<div style="border:1px solid rgba(255,152,0,.2);border-radius:4px;padding:8px;margin-bottom:6px;background:rgba(255,100,0,.04);">'+
            '<div style="color:'+confColor+';font-size:10px;letter-spacing:.08em;margin-bottom:4px;font-weight:bold;">⬤ CONFIANÇA '+conf+'</div>'+
            '<div style="color:#fff;font-size:11px;letter-spacing:.03em;">📍 '+parseFloat(c[0]).toFixed(4)+', '+parseFloat(c[1]).toFixed(4)+'</div>'+
            '<div style="color:rgba(255,255,255,.75);font-size:10px;margin-top:3px;">'+
            '🕐 '+c[5]+' '+c[6].slice(0,2)+':'+c[6].slice(2)+'h · '+
            '⚡ FRP: '+parseFloat(c[12]).toFixed(1)+' MW · '+
            '🛰 '+c[7]+'</div>'+
            '</div>';
        }
        body.innerHTML=html;
      }
      if(panel) panel.style.display='block';
    })
    .catch(function(e) { console.error('FIRMS error:', e); });
}

