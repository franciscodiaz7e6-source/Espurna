function exportMapPNG(){
  var menu = document.getElementById("rf-dots-menu");
  if(menu) menu.classList.remove("open");
  rfMenuOpen = false;

  var center = map.getCenter();
  var zoom = map.getZoom();

  // Serialitzar nodes (sense funcions)
  var nodes = (window.RFMulti && RFMulti.nodes ? RFMulti.nodes : []).map(function(n){
    return {
      id: n.id, lat: n.lat, lng: n.lng, elev: n.elev,
      label: n.label, colorIdx: n.colorIdx, params: n.params,
      results: n.results || []
    };
  });

  var payload = {
    nodes: nodes,
    center: { lat: center.lat, lng: center.lng },
    zoom: zoom,
    currentMap: window.currentMap || 'carto'
  };

  fetch('/screenshot/api/screenshot', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  }).then(function(r){
    if(!r.ok) throw new Error('Error servidor');
    return r.blob();
  }).then(function(blob){
    var url = URL.createObjectURL(blob);
    var link = document.createElement('a');
    link.download = 'cobertura_' + new Date().toISOString().slice(0,19).replace(/[:T]/g,'-') + '.png';
    link.href = url;
    link.click();
    URL.revokeObjectURL(url);
  }).catch(function(e){ alert('Error exportant: ' + e.message); });
}

// Auto-restaurar estat quan Puppeteer obre la pàgina amb ?capture=
(function(){
  if(!window.location.search.includes('capture=')) return;
  window.addEventListener('load', function(){
    setTimeout(function(){
      fetch('/screenshot/api/screenshot/state').then(function(r){ return r.json(); }).then(function(state){
        if(!state || !state.nodes || !state.nodes.length) return;
        // Centrar mapa
        if(state.center && map) map.setView([state.center.lat, state.center.lng], state.zoom);
        // Restaurar capa base
        if(state.currentMap === 'sat' && typeof satelliteLayer !== 'undefined'){
          if(typeof cartoLayer !== 'undefined') map.removeLayer(cartoLayer);
          satelliteLayer.addTo(map);
          window.currentMap = 'sat';
        }
        // Restaurar nodes amb resultats
        state.nodes.forEach(function(n){
          if(!n.results || !n.results.length) return;
          RFMulti.nodes.push(n);
          RFMulti.renderNode2D(n, map);
        });
        // Mostrar leyenda
        var leg = document.getElementById('rf-legend');
        if(leg) leg.style.display = 'flex';
      });
    }, 3000);
  });
})();

