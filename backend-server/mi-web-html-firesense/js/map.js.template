function pnShowModal(lat,lng,type){
  // Treure crosshair mentre s'escriu el nom
  if(!is3D){map.getContainer().style.cursor='default';map.getContainer().classList.remove('waiting-click');document.body.classList.remove('waiting-click');}
  else if(cesiumViewer){cesiumViewer.canvas.style.cursor='default';}
  // En 3D assegurar modal visible al centre
  var modal=document.getElementById('pn-modal');
  if(modal&&is3D){
    var _cm=document.getElementById('cesium-map');
    if(_cm&&modal.parentNode!==_cm){
      _cm.appendChild(modal);
      modal.style.position='absolute';
      modal.style.top='0';
      modal.style.left='0';
      modal.style.width='100%';
      modal.style.height='100%';
      modal.style.zIndex='99999';
      modal.style.paddingLeft='0';
    }
  }
  var typeLabels={gateway:'GATEWAY',sensor:'NODE SENSOR',torre:'TORRE'};
  var typeIcons={gateway:'📡',sensor:'🌡',torre:'🗼'};
  _pnPending={lat:lat,lng:lng,type:type};
  _pnPendingIs3D=is3D;
  _pnTech='lorawan';
  // Amagar selector si es torre
  var _techDiv=document.getElementById('pn-tech-lorawan');
  var _techDiv2=document.getElementById('pn-tech-meshcore');
  if(type==='torre'){
    if(_techDiv)_techDiv.parentElement.style.display='none';
  } else {
    if(_techDiv)_techDiv.parentElement.style.display='flex';
    pnSelectTech('lorawan');
  }
  var modal=document.getElementById('pn-modal');
  var title=document.getElementById('pn-modal-title');
  var input=document.getElementById('pn-modal-input');
  if(!modal)return;
  title.textContent=typeIcons[type]+' NOM DEL '+typeLabels[type];
  var _al=is3D?pnItems3D:pnItems;
  var count=_al.filter(function(i){return i.type===type;}).length+1;
  var defaults={gateway:'Gateway '+count,sensor:'Node Sensor '+count,torre:'Torre '+count};
  input.value=defaults[type];
  modal.style.display='flex';
  setTimeout(function(){input.focus();input.select();},50);
  // Enter per confirmar
  input.onkeydown=function(e){if(e.key==='Enter')pnModalConfirm();if(e.key==='Escape')pnModalCancel();};
}

function pnModalConfirm(){
  var modal=document.getElementById('pn-modal');
  var input=document.getElementById('pn-modal-input');
  if(!_pnPending)return;
  var name=input.value.trim()||'Node '+pnItems.length+1;
  modal.style.display='none';
  pnAddItem(_pnPending.lat,_pnPending.lng,_pnPending.type,name,_pnPendingIs3D);
  _pnPending=null;
  // Restaurar cursor crosshair per continuar posant nodes
  if(pnMode&&pnCurrentType){
    if(!is3D){map.getContainer().style.cursor='crosshair';}
    else if(cesiumViewer){cesiumViewer.canvas.style.cursor='crosshair';}
    var labels={gateway:'Gateway',sensor:'Node Sensor',torre:'Torre'};
    var icons={gateway:'📡',sensor:'🌡',torre:'🗼'};
    var hint=document.getElementById('los-hint');
    if(hint){hint.textContent=icons[pnCurrentType]+' Clica al mapa per posar '+labels[pnCurrentType];hint.style.display='block';}
  }
}

function pnModalCancel(){
  var modal=document.getElementById('pn-modal');
  if(modal){modal.style.display='none';modal.style.removeProperty("display");modal.style.display='none';}
  _pnPending=null;
  // Restaurar cursor si seguim en mode pn
  pnCurrentType=null;
  if(!is3D){map.getContainer().style.cursor='';map.getContainer().classList.remove('waiting-click');document.body.classList.remove('waiting-click');}
  else if(cesiumViewer){cesiumViewer.canvas.style.cursor='';}
  var hint=document.getElementById('los-hint');
  if(hint){hint.textContent='📍 Obre el menú ⋮ per seleccionar tipus';hint.style.display='block';}
}

function pnAddItem(lat,lng,type,customName,forceIs3D){
  var labels={gateway:'Gateway',sensor:'Node Sensor',torre:'Torre'};
  var _mode3D=(typeof forceIs3D!=='undefined')?forceIs3D:is3D;
  var _activeList=_mode3D?pnItems3D:pnItems;
  var defaultName=labels[type]+' '+(_activeList.filter(function(i){return i.type===type;}).length+1);
  var item={lat:lat,lng:lng,type:type,label:customName||defaultName,tech:_pnTech||'lorawan'};
  _activeList.push(item);
  // Marcador Leaflet (nomes 2D)
  if(!_mode3D){
  var _isMesh=item.tech==='meshcore';
  var _gwColor=_isMesh?'#ff6400':'#0288d1';
  var _snColor=_isMesh?'#00c080':'#EE2C2C';
  var icons={
    gateway: L.divIcon({className:'',html:'<div style="width:24px;height:24px;background:'+_gwColor+';border:2px solid #fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;box-shadow:0 2px 8px rgba(0,0,0,.5);">📡</div>',iconSize:[28,28],iconAnchor:[14,14]}),
    sensor:  L.divIcon({className:'',html:'<svg width="30" height="30" viewBox="0 0 500 500" xmlns="http://www.w3.org/2000/svg"><circle cx="250" cy="250" r="200" fill="#FFFFFF" stroke="#E0E0E0" stroke-width="2"/><circle cx="250" cy="250" r="185" fill="'+_snColor+'"/><g fill="white"><circle cx="250" cy="235" r="30"/><path d="M235 260 L265 260 L275 340 L225 340 Z"/><g fill="none" stroke="white" stroke-width="18" stroke-linecap="round"><path d="M210 195 A60 60 0 0 0 210 275"/><path d="M290 195 A60 60 0 0 1 290 275"/><path d="M185 170 A95 95 0 0 0 185 300"/><path d="M315 170 A95 95 0 0 1 315 300"/></g></g></svg>',iconSize:[28,28],iconAnchor:[14,14],popupAnchor:[0,-16]}),
    torre:   L.divIcon({className:'',html:'<svg width="22" height="22" viewBox="100 135 380 380" xmlns="http://www.w3.org/2000/svg"><defs><radialGradient id="bgBlue2" cx="32%" cy="24%" r="78%"><stop offset="0%" stop-color="#57a8f3"/><stop offset="38%" stop-color="#2c87d8"/><stop offset="72%" stop-color="#0f6fbe"/><stop offset="100%" stop-color="#005ea8"/></radialGradient></defs><circle cx="290" cy="325" r="190" fill="#f4f4f4"/><circle cx="290" cy="325" r="183" fill="url(#bgBlue2)"/><g fill="#f4f4f4"><path d="M194 233 H230 V255 H248 V233 H281 V255 H299 V233 H332 V255 H350 V233 H386 V286 H194 Z"/><path d="M214 296 H366 V451 H327 V362 C327 327 253 327 253 362 V451 H214 V296 Z"/><rect x="206" y="392" width="18" height="59"/><rect x="356" y="392" width="18" height="59"/></g><path d="M271 451 V366 C271 334 309 334 309 366 V451 Z" fill="#0f6fbe"/></svg>',iconSize:[22,22],iconAnchor:[11,11],popupAnchor:[0,-14]})
  };
  var m=L.marker([lat,lng],{icon:icons[type]}).bindPopup('<b>'+item.label+'</b><br>'+lat.toFixed(5)+', '+lng.toFixed(5));
  m.addTo(map);
  item.marker=m;
  pnMarkers.push(m);
  } // end !is3D
  // Entitat Cesium (nomes en 3D)
  if(_mode3D&&cesiumViewer){
    var _isMesh3=item.tech==='meshcore';
    var cesColors={gateway:_isMesh3?'#ff6400':'#0288d1',sensor:_isMesh3?'#00c080':'#ff3333',torre:'#ffab40'};
    // Crear canvas per a la forma
    function makeCesiumCanvas(shape, color){
      var c=document.createElement('canvas');c.width=32;c.height=32;
      var ctx=c.getContext('2d');
      ctx.fillStyle=color;ctx.strokeStyle='#fff';ctx.lineWidth=2;
      if(shape==='circle'){
        ctx.beginPath();ctx.arc(16,16,13,0,Math.PI*2);ctx.fill();ctx.stroke();
      } else if(shape==='triangle'){
        ctx.beginPath();ctx.moveTo(16,3);ctx.lineTo(29,27);ctx.lineTo(3,27);ctx.closePath();ctx.fill();ctx.stroke();
      } else if(shape==='hexagon'){
        ctx.beginPath();
        for(var i=0;i<6;i++){var a=Math.PI/180*(60*i-30);ctx.lineTo(16+13*Math.cos(a),16+13*Math.sin(a));}
        ctx.closePath();ctx.fill();ctx.stroke();
      }
      return c;
    }
    var shapes={gateway:'circle',sensor:'triangle',torre:'hexagon'};
    var cesCanvas=makeCesiumCanvas(shapes[type],cesColors[type]);
    var ent=cesiumViewer.entities.add({
      position:Cesium.Cartesian3.fromDegrees(lng,lat,30),
      billboard:{
        image:cesCanvas,
        width:28,height:28,
        heightReference:Cesium.HeightReference.CLAMP_TO_GROUND,
        disableDepthTestDistance:Number.POSITIVE_INFINITY,
        verticalOrigin:Cesium.VerticalOrigin.BOTTOM
      },
      label:{text:item.label,font:'bold 10px Share Tech Mono',fillColor:Cesium.Color.WHITE,outlineColor:Cesium.Color.BLACK,outlineWidth:2,style:Cesium.LabelStyle.FILL_AND_OUTLINE,pixelOffset:new Cesium.Cartesian2(0,-34),heightReference:Cesium.HeightReference.CLAMP_TO_GROUND,disableDepthTestDistance:Number.POSITIVE_INFINITY}
    });
    item.entity=ent;
  }
  pnRenderPanel();
  // Reset cursor despres d afegir
  pnCurrentType=null;
  if(!is3D){map.getContainer().style.cursor='';map.getContainer().classList.remove('waiting-click');document.body.classList.remove('waiting-click');}else if(cesiumViewer){cesiumViewer.canvas.style.cursor='';}
  var _hint=document.getElementById('los-hint');
  if(_hint){_hint.textContent='📍 Obre el menu per seleccionar tipus';}
}
function pnRemoveItem(idx){
  var _activeList=is3D?pnItems3D:pnItems;
  var item=_activeList[idx];
  if(item.marker){try{map.removeLayer(item.marker);}catch(e){}}
  if(item.entity&&cesiumViewer){try{cesiumViewer.entities.remove(item.entity);}catch(e){}}
  _activeList.splice(idx,1);
  pnRenderPanel();
}

function pnClearAll(){
  var _activeList=is3D?pnItems3D:pnItems;
  _activeList.forEach(function(item){
    if(item.marker){try{map.removeLayer(item.marker);}catch(e){}}
    if(item.entity&&cesiumViewer){try{cesiumViewer.entities.remove(item.entity);}catch(e){}}
  });
  pnItems=[];
  pnMenuOpen=false;
  document.getElementById('pn-dots-menu').classList.remove('open');
  pnRenderPanel();
}

function pnRenderPanel(){

  // Agafar el panel-body correcte (el del panel visible)
  var _panels=document.querySelectorAll('#pn-panel');
  var _visPanel=null;
  _panels.forEach(function(p){if(p.style.display!=='none')_visPanel=p;});
  var body=_visPanel?_visPanel.querySelector('#pn-panel-body'):document.getElementById('pn-panel-body');
  if(!body)return;
  var _activeList=window.is3D?pnItems3D:pnItems;
  var _pp2=document.getElementById('pn-panel');
  if(_pp2&&!pnMode){_pp2.style.display='none';return;}
  if(!_activeList.length){
    body.innerHTML='<div style="color:rgba(0,229,255,.3);font-size:9px;padding:4px 0;">Cap node posat yet. Usa el menú ⋮ per afegir.</div>';
    return;
  }
  var typeColors={gateway:'#0288d1',sensor:'#00e5ff',torre:'#ffab40'};
  var techColors={lorawan:'#00e5ff',meshcore:'#ff6400'};
  var typeIcons={gateway:'📡',sensor:'🌡',torre:'🗼'};
  body.innerHTML=_activeList.map(function(item,i){
    return '<div style="display:flex;align-items:center;justify-content:space-between;padding:5px 0;border-bottom:1px solid rgba(0,229,255,.08);">'+
      '<div><span style="color:'+typeColors[item.type]+';margin-right:4px;">'+typeIcons[item.type]+'</span>'+
      '<span style="color:#fff;font-size:9px;">'+item.label+'</span>'+
      (item.type!=='torre'?'<span style="background:'+(item.tech==='meshcore'?'rgba(255,100,0,.2)':'rgba(0,229,255,.15)')+';color:'+(item.tech==='meshcore'?'#ff8c40':'#00e5ff')+';font-size:8px;margin-left:5px;border:1px solid currentColor;padding:1px 4px;border-radius:3px;font-weight:bold;">'+(item.tech==='meshcore'?'MESH':'LORA')+'</span>':'')+'<br>'+
      '<span style="color:rgba(0,229,255,.4);font-size:8px;">'+item.lat.toFixed(5)+', '+item.lng.toFixed(5)+'</span></div>'+
      '<button onclick="pnRemoveItem('+i+')" style="background:rgba(255,23,68,.1);border:1px solid rgba(255,23,68,.3);color:#ff1744;font-family:Share Tech Mono,monospace;font-size:10px;padding:2px 6px;border-radius:3px;cursor:pointer;">✕</button>'+
      '</div>';
  }).join('');
}

function pnExportCSV(){
  var rows=['Tipus,Nom,Tecnologia,Latitud,Longitud'];
  var _activeList=is3D?pnItems3D:pnItems;
  _activeList.forEach(function(item){
    rows.push([item.type,item.label,item.tech||'lorawan',item.lat.toFixed(6),item.lng.toFixed(6)].join(','));
  });
  var blob=new Blob([rows.join('\n')],{type:'text/csv'});
  var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='espurna_nodes.csv';a.click();
}
