          '<div style="color:rgba(255,255,255,.4);font-size:8px;margin-bottom:6px;">'+dateStr+'</div>'+
          '<div style="display:grid;grid-template-columns:1fr 1fr;gap:4px;">';
        readings.forEach(function(r){
          var p=r.param.toLowerCase();
          var lim=limits[p];
          var pct=lim?Math.min(100,Math.round(r.value/lim*100)):null;
          var color=pct===null?'#aaa':pct>100?'#ff1744':pct>75?'#ff9800':pct>50?'#ffeb3b':'#00ff88';
          var qualitat=pct===null?'—':pct>100?'DOLENTA':pct>75?'MODERADA':pct>50?'ACCEPTABLE':'BONA';
          html+='<div style="background:rgba(255,255,255,.05);border-radius:4px;padding:7px;">'+
            '<div style="color:rgba(255,255,255,.6);font-size:10px;font-weight:bold;margin-bottom:3px;">'+(paramNames[p]||r.param.toUpperCase())+'</div>'+
            '<div style="color:#fff;font-size:13px;font-weight:bold;">'+r.value+' <span style="font-size:9px;color:rgba(255,255,255,.5);">'+(paramUnits[p]||'')+'</span></div>'+
            '<div style="color:'+color+';font-size:9px;font-weight:bold;margin-top:2px;">'+qualitat+'</div>'+
            '</div>';
        });
        html+='</div></div>';
      });
      html+='<div style="color:rgba(255,255,255,.3);font-size:8px;margin-top:4px;border-top:1px solid rgba(0,229,255,.1);padding-top:6px;">Limits OMS · Font: OpenAQ</div>';
      body.innerHTML=html;
    })
    .catch(function(){body.innerHTML='<div style="color:#ff4444;font-size:10px;">Error carregant dades</div>';});
}

