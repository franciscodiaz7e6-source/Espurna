// FSPL
function calcFSPL(distM, freqMHz){
  return 20*Math.log10(distM) + 20*Math.log10(freqMHz*1e6) - 147.55;
}

// Fresnel radius
function fresnelR(d1, d2, freqMHz){
  var lambda = 3e8 / (freqMHz * 1e6);
  if(d1 <= 0 || d2 <= 0) return 0;
  var r = Math.sqrt(lambda * d1 * d2 / (d1 + d2));
  var dist = d1 + d2;
  var visMin = Math.min(dist * 0.05, 35) * Math.sin(Math.PI * d1 / dist);
  return Math.max(r, visMin);
}
// Genera array de Fresnel amb forma el·liptica correcta afegint punts extra als extrems
function fresnelArray(distances, losHeights, dist, freqMHz, sign){
  var arr = distances.map(function(d, i){
    var d1=d, d2=dist-d;
    if(d1<=0||d2<=0) return losHeights[i];
    return losHeights[i] + sign * fresnelR(d1, d2, freqMHz);
  });
  // Inserir punts just despres del primer i just abans de l'ultim
  // per forcar la corba a pujar/baixar des del punt
  var step = dist / distances.length;
  var d1s = step * 0.5;
  var r1 = fresnelR(d1s, dist - d1s, freqMHz);
  arr[0] = losHeights[0]; // extrem = 0
  arr[1] = losHeights[1] + sign * r1 * 0.3; // segon punt petit per forcar curvatura
  return arr;
}

async function runElevationProfile(posA, posB){
  if(!cesiumViewer) return;
  var scene = cesiumViewer.scene;

  var cartA = Cesium.Cartographic.fromCartesian(posA);
  var cartB = Cesium.Cartographic.fromCartesian(posB);

  var latA = Cesium.Math.toDegrees(cartA.latitude);
  var lngA = Cesium.Math.toDegrees(cartA.longitude);
  var latB = Cesium.Math.toDegrees(cartB.latitude);
  var lngB = Cesium.Math.toDegrees(cartB.longitude);

  var elevA = cartA.height;
  var elevB = cartB.height;
  // Mostrar valor provisional fins que clampToHeight acabi

  // Total distance
  var distTotal = Cesium.Cartesian3.distance(posA, posB);

  // Show panel
  document.getElementById('elev-panel').style.display='block';
  if(typeof closeAllNasaPanels==='function') closeAllNasaPanels();
  var _rfl=document.getElementById('rf-legend');if(_rfl)_rfl.style.visibility='hidden';
  var _ia3=document.getElementById('elev-info-a');
  var _ib3=document.getElementById('elev-info-b');
  var _irf3=document.getElementById('elev-info-rf');
  // Collserola check immediat (sense esperar OSM) - amb geoid
  var _geoidQ=49;
  var _collsLatQ=41.41702,_collsLngQ=2.11436;
  var _bhAq=Math.sqrt(Math.pow(latA-_collsLatQ,2)+Math.pow(lngA-_collsLngQ,2))<0.0003?288:0;
  var _bhBq=Math.sqrt(Math.pow(latB-_collsLatQ,2)+Math.pow(lngB-_collsLngQ,2))<0.0003?288:0;
  var _eAqSol=(elevA-_geoidQ), _eBqSol=(elevB-_geoidQ);
  var _eAq=_eAqSol+_bhAq, _eBq=_eBqSol+_bhBq;
  if(_ia3)_ia3.innerHTML='<span style="color:#5b9bd5 !important">Origen A:</span> <span id="elev-a-coords" style="color:#fff !important">'+latA.toFixed(5)+', '+lngA.toFixed(5)+'</span> <span style="color:#555 !important">|</span> <span style="color:#5b9bd5 !important">Elev:</span> <span id="elev-a-val" style="color:#fff !important">'+(_bhAq>0?_eAq.toFixed(1)+'m ('+_eAqSol.toFixed(0)+'m sol + '+_bhAq+'m estructura)':_eAqSol.toFixed(1)+'m')+'</span>';
  if(_ib3)_ib3.innerHTML='<span style="color:#5b9bd5 !important">Destí B:</span> <span id="elev-b-coords" style="color:#fff !important">'+latB.toFixed(5)+', '+lngB.toFixed(5)+'</span> <span style="color:#555 !important">|</span> <span style="color:#5b9bd5 !important">Elev:</span> <span id="elev-b-val" style="color:#fff !important">'+(_bhBq>0?_eBq.toFixed(1)+'m ('+_eBqSol.toFixed(0)+'m sol + '+_bhBq+'m estructura)':_eBqSol.toFixed(1)+'m')+'</span>';
  // Valors ja mostrats immediatament abans - no cal Promise OSM
  var fspl = calcFSPL(distTotal, elevFreq);
  if(_irf3)_irf3.innerHTML='<span style="color:#ff9800 !important">RF:</span> <span style="color:#fff !important">'+elevFreq+'MHz</span> <span style="color:#555 !important">|</span> <span style="color:#ff9800 !important">Dist:</span> <span style="color:#fff !important">'+(distTotal/1000).toFixed(2)+'km</span> <span style="color:#555 !important">|</span> <span style="color:#ff9800 !important">FSPL:</span> <span style="color:#fff !important">'+fspl.toFixed(1)+'dB</span> <span style="color:#555 !important">|</span> <span style="color:#ff9800 !important">Refrac:</span> <span style="color:#fff !important">0.25</span>';

  // Hint
    document.getElementById('los-hint').textContent = 'Calculant perfil...';

  // Mostrejar punts intermedis
  var positions = [];
  var distances = [];
  var heights = [];

  var promises = [];
  for(var i=0; i<=LOS_SAMPLES; i++){
    var t = i/LOS_SAMPLES;
    var pos = Cesium.Cartesian3.lerp(posA, posB, t, new Cesium.Cartesian3());
    positions.push(pos);
    distances.push(t * distTotal);
  }
  // Sample terreny amb sampleTerrainMostDetailed (només terreny, sense edificis)
  try {
    var sampledHeights = await Cesium.sampleTerrainMostDetailed(
      cesiumViewer.terrainProvider,
      positions.map(function(p){
        var c = Cesium.Cartographic.fromCartesian(p);
        return new Cesium.Cartographic(c.longitude, c.latitude);
      })
    );
    heights = sampledHeights.map(function(c){ return c.height || 0; });
  } catch(e) {
    console.warn('sampleTerrain fallback:', e);
    heights = positions.map(function(p){
      return Cesium.Cartographic.fromCartesian(p).height || 0;
    });
  }

  // LOS heights A→B - afegir estructura si és la torre de Collserola
  var _collsLat=41.41702,_collsLng=2.11436;
  var _bhA=0,_bhB=0;
  var _geoid3=49;
  if(Math.sqrt(Math.pow(latA-_collsLat,2)+Math.pow(lngA-_collsLng,2))<0.0003)_bhA=288;
  if(Math.sqrt(Math.pow(latB-_collsLat,2)+Math.pow(lngB-_collsLng,2))<0.0003)_bhB=288;
  elevA=elevA-_geoid3; elevB=elevB-_geoid3;
  heights=heights.map(function(h){return h-_geoid3;});
  var elevAlos=elevA+_bhA, elevBlos=elevB+_bhB;
  var losHeights = distances.map(function(d){
    return elevAlos + (elevBlos - elevAlos) * (d / distTotal);
  });

  // Detect obstructions
  var firstObstruction = -1;
  for(var i=0; i<heights.length; i++){
    var d1=distances[i],d2=distTotal-distances[i],frM=(d1>0&&d2>0)?fresnelR(d1,d2,elevFreq):0;
      if(heights[i] > losHeights[i] - frM){
      firstObstruction = i;
      break;
    }
  }

  // Fresnel zones
  var _frMid2=fresnelR(distTotal/2,distTotal/2,elevFreq);
  var fresnelTop = distances.map(function(d, i){
    return losHeights[i]+_frMid2*Math.sin(Math.PI*d/distTotal);
  });
  var fresnelBot = distances.map(function(d, i){
    return losHeights[i]-_frMid2*Math.sin(Math.PI*d/distTotal);
  });


  // Save data
  elevData = {
    distTotal: distTotal, freq: elevFreq, fspl: fspl,
    pointA: {lat:latA,lng:lngA,elev:elevA},
    pointB: {lat:latB,lng:lngB,elev:elevB},
    samples: distances.map(function(d,i){
      return {dist:d,terrain:heights[i],los:losHeights[i]};
    })
  };

  renderElevPanel({
    distances: distances, heights: heights,
    losHeights: losHeights, firstObstruction: firstObstruction,
    fresnelTop: fresnelTop, fresnelBot: fresnelBot, eAreal: elevAlos, eBreal: elevBlos
  });

  document.getElementById('los-hint').textContent =
    firstObstruction>=0 ? '🔴 OBSTRUÏDA — a '+(distances[firstObstruction]/1000).toFixed(2)+'km' : '🟢 VISIBLE — Visió directa OK';
}

function renderElevPanel(d){
  if(elevChart){ elevChart.destroy(); elevChart=null; }
  var ctx = document.getElementById('elev-chart').getContext('2d');

  // LOS colors - verd fins obstrucció, vermell després
  var losColors = d.distances.map(function(_,i){
    return (d.firstObstruction>=0 && i>=d.firstObstruction) ? 'rgba(255,23,68,1)' : 'rgba(0,255,136,1)';
  });

  var _distRef2 = d.distTotal || d.distances[d.distances.length-1];
  var _fr1real = fresnelR(_distRef2/2,_distRef2/2,elevFreq);
  var _fr1vis = _fr1real;
  // Zones 2 i 3 - radis correctes: r_n = r1 * sqrt(n)
  var _fr2 = _fr1vis * Math.sqrt(2);
  var _fr3 = _fr1vis * Math.sqrt(3);
  window._fresnelDrawData = {
    top: d.fresnelTop, bot: d.fresnelBot,
    top2: d.distances.map(function(d2,i){return d.losHeights[i]+_fr2*Math.sin(Math.PI*d2/_distRef2);}),
    bot2: d.distances.map(function(d2,i){return d.losHeights[i]-_fr2*Math.sin(Math.PI*d2/_distRef2);}),
    top3: d.distances.map(function(d2,i){return d.losHeights[i]+_fr3*Math.sin(Math.PI*d2/_distRef2);}),
    bot3: d.distances.map(function(d2,i){return d.losHeights[i]-_fr3*Math.sin(Math.PI*d2/_distRef2);})
  };
  elevChart = new Chart(ctx, {
    type: 'line',
    plugins: [window._fresnelEllipsePlugin],
    data: {
      labels: d.distances.map(function(v){ return (v/1000).toFixed(2); }),
      datasets: [
        // Terreny - exacte MeshCore amb gradient
        {
          label: 'Terreny',
          data: d.heights,
          fill: 'origin',
          backgroundColor: (function(){
            var el=document.getElementById('elev-chart');
            var c=el.getContext('2d');
            var h=el.offsetHeight||220;
            var g=c.createLinearGradient(0,0,0,h);
            g.addColorStop(0,'rgba(140,95,45,1)');
            g.addColorStop(0.45,'rgba(90,62,27,.55)');
            g.addColorStop(1,'rgba(20,10,5,.1)');
            return g;
          })(),
          borderColor: '#c8a84b',
          borderWidth: 1.5,
          pointRadius: 0, tension: 0.3, order: 4
        },
        // Punt A/B estructura (forçar escala Y correcta)
        {
          label: 'Estructura',
          data: d.distances.map(function(_,i){
            if(i===0) return d.eAreal||d.losHeights[0];
            if(i===d.distances.length-1) return d.eBreal||d.losHeights[d.losHeights.length-1];
            return null;
          }),
          fill: false, borderColor: 'transparent',
          pointRadius: 0, tension: 0, order: 0, spanGaps: false
        },
        // LOS
        {
          label: 'LOS',
          data: d.losHeights,
          fill: false,
          borderColor: '#ff4444',
          borderWidth: 2.5,
          pointRadius: function(ctx){
            var i=ctx.dataIndex,n=d.distances.length-1;
            return (i===0||i===n)?6:0;
          },
          pointBackgroundColor: '#00e5ff',
          pointBorderColor: '#fff',
          pointBorderWidth: 2,
          pointStyle: 'circle',
          tension: 0, order: 1, clip: false
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      animation: {duration: 400},
      plugins: {
        legend: {display: false},
        tooltip: {
          mode: 'index', intersect: false,
          backgroundColor: 'rgba(4,14,22,.95)',
          borderColor: 'rgba(0,229,255,.3)', borderWidth: 1,
          titleColor: '#00e5ff', bodyColor: 'rgba(0,229,255,.7)',
          titleFont: {family:'Share Tech Mono', size:9},
          bodyFont: {family:'Share Tech Mono', size:8},
          callbacks: {
            title: function(items){ return 'Dist: '+items[0].label+'km'; },
            label: function(item){
              if(item.datasetIndex===0) return 'Terreny: '+item.raw.toFixed(1)+'m';
              if(item.datasetIndex===3) return 'LOS: '+item.raw.toFixed(1)+'m';
              return null;
            }
          }
        }
      },
      scales: {
        x: {
          grid: {color:'rgba(0,229,255,.06)'},
          ticks: {color:'rgba(0,229,255,.5)',font:{family:'Share Tech Mono',size:8},
            maxTicksLimit:8,
            callback:function(v,i){ return d.distances[i]?(d.distances[i]/1000).toFixed(1)+'km':null; }
          },
          title: {display:true,text:'Distància (km)',color:'rgba(0,229,255,.4)',
            font:{family:'Share Tech Mono',size:8}}
        },
        y: {
          min: (function(){
            var terrVals=d.heights.concat(d.fresnelBot3||[]).filter(function(v){return v!=null&&!isNaN(v);});
            if(d.eAreal) terrVals.push(d.eAreal);
            if(d.eBreal) terrVals.push(d.eBreal);
            var mn=Math.min.apply(null,terrVals);
            var mx=Math.max.apply(null,terrVals);
            var pad=Math.max(10, Math.round((mx-mn)*0.05));
            return Math.floor((mn-pad)/10)*10;
          })(),
          max: (function(){
            var terrVals=d.heights.concat(d.losHeights).concat(d.fresnelTop3||[]).filter(function(v){return v!=null&&!isNaN(v);});
            if(d.eAreal) terrVals.push(d.eAreal);
            if(d.eBreal) terrVals.push(d.eBreal);
            var mx=Math.max.apply(null,terrVals);
            var mn=Math.min.apply(null,terrVals);
            var pad=Math.max(20, Math.round((mx-mn)*0.15));
            return Math.ceil((mx+pad)/10)*10;
          })(),
          grid: {color:'rgba(0,229,255,.06)'},
          ticks: {color:'rgba(0,229,255,.5)',font:{family:'Share Tech Mono',size:8},
            callback:function(v){ return v.toFixed(0)+'m'; }
          },
          title: {display:true,text:'Elevació (m)',color:'rgba(0,229,255,.4)',
            font:{family:'Share Tech Mono',size:8}}
        }
      }
    }
  });
}

