  windVisible=true;
  fetch('/wind-grid')
    .then(function(r){return r.json();})
    .then(function(data){
      if(windLayer){map.removeLayer(windLayer);windLayer=null;}
      // Llegenda vent
      var wleg=document.createElement('div');
      wleg.id='wind-legend';
      wleg.style.cssText='position:absolute;bottom:20px;left:12px;z-index:2001;background:rgba(2,8,14,.92);border:1px solid rgba(0,229,255,.3);border-radius:6px;padding:10px 14px;font-family:Share Tech Mono,monospace;font-size:9px;color:rgba(255,255,255,.7);pointer-events:none;';
      wleg.innerHTML='<div style="color:#00e5ff;font-size:10px;font-weight:bold;margin-bottom:6px;letter-spacing:.08em;">🌬 VENT EN VIU</div>'+
        '<div style="display:flex;align-items:center;gap:6px;margin-bottom:3px;"><div style="width:24px;height:3px;background:#00e5ff;"></div> Calma (&lt;5 km/h)</div>'+
        '<div style="display:flex;align-items:center;gap:6px;margin-bottom:3px;"><div style="width:24px;height:3px;background:#0088ff;"></div> Moderat (5-15 km/h)</div>'+
        '<div style="display:flex;align-items:center;gap:6px;margin-bottom:3px;"><div style="width:24px;height:3px;background:#ff4444;"></div> Fort (&gt;15 km/h)</div>'+
        '<div style="display:flex;align-items:center;gap:6px;"><div style="width:24px;height:3px;background:#ffffff;"></div> Extrem (&gt;30 km/h)</div>';
      var _mc=is3D?document.getElementById('cesium-map'):document.getElementById('map');
      if(_mc)_mc.appendChild(wleg);else document.body.appendChild(wleg);
      if(is3D && cesiumViewer){
        if(window._cesiumWindEntities){window._cesiumWindEntities.forEach(function(e){try{cesiumViewer.entities.remove(e);}catch(ex){}});}
        if(window._cesiumWindInterval){clearInterval(window._cesiumWindInterval);window._cesiumWindInterval=null;}
        window._cesiumWindEntities=[];
        var uArr=data[0].data,vArr=data[1].data;
        var header=data[0].header;
        var nx=header.nx,ny=header.ny,lo1=header.lo1,la1=header.la1,dx=header.dx,dy=header.dy;
        // Crear fletxes animades (polylines que es mouen)
        var particles=[];
        var nPart=1500;
        for(var p=0;p<nPart;p++){
          var rix=Math.floor(Math.random()*nx);
          var riy=Math.floor(Math.random()*ny);
          particles.push({
            lng:lo1+rix*dx, lat:la1-riy*dy,
            age:Math.floor(Math.random()*80),
            maxAge:60+Math.floor(Math.random()*40)
          });
        }
        // Crear entitats polyline per cada partícula
        particles.forEach(function(p){
          var cix=Math.min(nx-1,Math.max(0,Math.round((p.lng-lo1)/dx)));
          var ciy=Math.min(ny-1,Math.max(0,Math.round((la1-p.lat)/dy)));
          var u=uArr[ciy*nx+cix]||0,v=vArr[ciy*nx+cix]||0;
          var spd=Math.sqrt(u*u+v*v)*3.6;
          var col2=spd>30?'#ffffff':spd>15?'#ff4444':spd>5?'#0088ff':'#00e5ff';
          var ang=Math.atan2(u,v);
          var len=0.03*Math.max(0.5,Math.min(spd/8,2));
          var eLng=p.lng+len*Math.sin(ang), eLat=p.lat+len*Math.cos(ang);
          p.entity=cesiumViewer.entities.add({
            polyline:{
              positions:new Cesium.CallbackProperty(function(pp){
                return function(){
                  var cx=Math.min(nx-1,Math.max(0,Math.round((pp.lng-lo1)/dx)));
                  var cy=Math.min(ny-1,Math.max(0,Math.round((la1-pp.lat)/dy)));
                  var uu=uArr[cy*nx+cx]||0,vv=vArr[cy*nx+cx]||0;
                  var aa=Math.atan2(uu,vv);
                  var ss=Math.sqrt(uu*uu+vv*vv)*3.6;
                  var ll=0.015*Math.max(0.5,Math.min(ss/8,2));
                  var opacity=Math.min(1,pp.age/10)*Math.max(0,1-(pp.age/pp.maxAge));
                  return Cesium.Cartesian3.fromDegreesArray([pp.lng,pp.lat,pp.lng+ll*Math.sin(aa),pp.lat+ll*Math.cos(aa)]);
                };
              }(p),false),
              width:2,
              material:Cesium.Color.fromCssColorString(col2).withAlpha(0.8),
              clampToGround:true
            }
          });
          window._cesiumWindEntities.push(p.entity);
        });
        // Animació
        window._cesiumWindInterval=setInterval(function(){
          if(!windVisible){clearInterval(window._cesiumWindInterval);return;}
          particles.forEach(function(p){
            p.age+=1;
            if(p.age>p.maxAge){
              p.lng=lo1+Math.random()*nx*dx;
              p.lat=(la1-ny*dy)+Math.random()*ny*dy;
              p.age=0;
              p.maxAge=60+Math.floor(Math.random()*40);
            }
            var cix=Math.min(nx-1,Math.max(0,Math.round((p.lng-lo1)/dx)));
            var ciy=Math.min(ny-1,Math.max(0,Math.round((la1-p.lat)/dy)));
            var u=uArr[ciy*nx+cix]||0,v=vArr[ciy*nx+cix]||0;
            var spd=Math.sqrt(u*u+v*v)*3.6;
            var speed=0.001*Math.max(0.5,spd/5);
            p.lng+=u*speed*0.015;
            p.lat+=v*speed*0.015;
            // Color dinàmic
            var col2=spd>30?'#ffffff':spd>15?'#ff4444':spd>5?'#0088ff':'#00e5ff';
            var opacity=Math.min(1,p.age/10)*(1-p.age/p.maxAge);
            if(p.entity&&p.entity.polyline){
              p.entity.polyline.material=Cesium.Color.fromCssColorString(col2).withAlpha(Math.max(0.1,opacity));
            }
          });
        },30);
      } else {
        windLayer=L.velocityLayer({
          displayValues:true,
          displayOptions:{velocityType:'Wind',position:'bottomleft',emptyString:'Sense dades',angleConvention:'bearingCW',speedUnit:'km/h'},
          data:data,maxVelocity:15,
          colorScale:['#00e5ff','#0088ff','#ff4444','#ffffff'],
          lineWidth:2,particleAge:64,particleMultiplier:0.005
        });
        windLayer.addTo(map);
      }
    })
    .catch(function(e){console.error('Wind error:',e);});
}

