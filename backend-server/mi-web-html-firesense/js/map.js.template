// Plugin global per línies discontínues (Fresnel)
Chart.register({
  id:'dashedLines',
  beforeDatasetDraw:function(chart,args){
    var ds=chart.data.datasets[args.index];
    if(ds && ds.borderDash){
      chart.ctx.save();
      chart.ctx.setLineDash(ds.borderDash);
    }
    return true;
  },
  afterDatasetDraw:function(chart,args){
    var ds=chart.data.datasets[args.index];
    if(ds && ds.borderDash){
      chart.ctx.setLineDash([]);
      chart.ctx.restore();
    }
  }
});

