          '<div style="margin-bottom:10px;"><div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;">'+
          '<div style="background:rgba(255,255,255,.04);border-radius:4px;padding:8px;"><div style="color:rgba(255,255,255,.5);font-size:8px;letter-spacing:.08em;margin-bottom:3px;">NDVI</div><div style="color:#fff;font-size:15px;font-weight:bold;">'+ndviRaw.toFixed(3)+'</div><div style="color:rgba(255,255,255,.3);font-size:7px;">Index vegetació</div></div>'+
          (eviRaw!==null?'<div style="background:rgba(255,255,255,.04);border-radius:4px;padding:8px;"><div style="color:rgba(255,255,255,.5);font-size:8px;letter-spacing:.08em;margin-bottom:3px;">EVI</div><div style="color:#fff;font-size:15px;font-weight:bold;">'+eviRaw.toFixed(3)+'</div><div style="color:rgba(255,255,255,.3);font-size:7px;">Index millorat</div></div>':'<div></div>')+
          (nirRaw?'<div style="background:rgba(255,255,255,.04);border-radius:4px;padding:8px;"><div style="color:rgba(255,255,255,.5);font-size:8px;letter-spacing:.08em;margin-bottom:3px;">NIR</div><div style="color:#fff;font-size:15px;font-weight:bold;">'+nirRaw.toFixed(3)+'</div><div style="color:rgba(255,255,255,.3);font-size:7px;">Infraroig proper</div></div>':'<div></div>')+
