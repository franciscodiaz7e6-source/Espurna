  losMode = true;
  if(cesiumViewer)cesiumViewer.canvas.style.cursor='crosshair';
  if(typeof map!=='undefined'&&map&&!is3D){map.getContainer().style.cursor='crosshair';map.getContainer().classList.add('waiting-click');document.body.classList.add('waiting-click');document.documentElement.style.cursor='crosshair';}
  var hint = document.getElementById('los-hint');
  hint.style.display = 'block';
  var _pts = is3D ? losPoints : (window.losPoints2D||[]);
  if(_pts.length===0){
    hint.textContent = 'Click per posar punt A (origen)';
  } else if(_pts.length===1){
    hint.textContent = 'Click per posar punt B (destí)';
  } else {
    // Reiniciar
    if(losEntityA){ try{cesiumViewer.entities.remove(losEntityA);}catch(e){} losEntityA=null; }
    if(losEntityB){ try{cesiumViewer.entities.remove(losEntityB);}catch(e){} losEntityB=null; }
    if(losEntityLine){ try{cesiumViewer.entities.remove(losEntityLine);}catch(e){} losEntityLine=null; }
    losPrimitives.forEach(function(p){try{cesiumViewer.entities.remove(p);}catch(e){try{cesiumViewer.scene.primitives.remove(p);}catch(e2){}}});
    losPrimitives=[];
    if(window.losMarker2DA){try{map.removeLayer(window.losMarker2DA);}catch(e){}window.losMarker2DA=null;}
    if(window.losMarker2DB){try{map.removeLayer(window.losMarker2DB);}catch(e){}window.losMarker2DB=null;}
    if(window.losLine2D){try{map.removeLayer(window.losLine2D);}catch(e){}window.losLine2D=null;}
    window.losPoints2D=[];
    document.getElementById('elev-panel').style.display='none';
    losPoints=[];
    elevClose();
    hint.textContent = 'Click per posar nou punt A (origen)';
  }
}

