window.runElevationProfile2D=function(latA,lngA,eA,latB,lngB,eB,dist,elevs,bldHeights){
  console.log('[2D Profile] called, elevs:',elevs.length,'dist:',dist,'eA:',eA,'eB:',eB,'heights:',elevs);
  var n=elevs.length;
  var distances=elevs.map(function(_,i){return dist*i/(n-1);});
  var heights=elevs.map(function(e){return e||0;});

  var bh=bldHeights||[2,2];
  // Collserola tower override
  var _cLat=41.41702,_cLng=2.11436;
  if(Math.sqrt(Math.pow(latA-_cLat,2)+Math.pow(lngA-_cLng,2))<0.0001) bh[0]=288;
  if(Math.sqrt(Math.pow(latB-_cLat,2)+Math.pow(lngB-_cLng,2))<0.0001) bh[1]=288;
  // Limitar altura estructura a 50m maxim (evita valors incorrectes OSM), excepte torre
  bh=[bh[0]===288?288:Math.min(bh[0]||2,50),bh[1]===288?288:Math.min(bh[1]||2,50)];
  var eAreal=eA+bh[0], eBreal=eB+bh[1];
  var R_eff=8500000;
  var losHeights=distances.map(function(d){
    var lineal=eAreal+(eBreal-eAreal)*(d/dist);
    var d1=d,d2=dist-d;
    var curv=(d1*d2)/(2*R_eff);
    return lineal-curv;
  });
  var _frMid=fresnelR(dist/2,dist/2,elevFreq);
  var fresnelTop=distances.map(function(d,i){
    // Usar el segon i penultim punt com a primer/ultim per evitar aplanament
    var dEff = dist/(distances.length-1);
    var d1 = Math.max(d, dEff);
    var d2 = Math.max(dist-d, dEff);
    return losHeights[i]+_frMid*Math.sin(Math.PI*d1/(d1+d2));
  });
  var fresnelBot=distances.map(function(d,i){
    var dEff = dist/(distances.length-1);
    var d1 = Math.max(d, dEff);
    var d2 = Math.max(dist-d, dEff);
    return losHeights[i]-_frMid*Math.sin(Math.PI*d1/(d1+d2));
  });

  // Fresnel zona 2 (r*sqrt(2)) i zona 3 (r*sqrt(3))
  var _frMid2=_frMid*Math.sqrt(2);
  var _frMid3=_frMid*Math.sqrt(3);
  var fresnelTop2=distances.map(function(d,i){
    var dEff=dist/(distances.length-1);
    var d1=Math.max(d,dEff),d2=Math.max(dist-d,dEff);
    return losHeights[i]+_frMid2*Math.sin(Math.PI*d1/(d1+d2));
  });
  var fresnelBot2=distances.map(function(d,i){
    var dEff=dist/(distances.length-1);
    var d1=Math.max(d,dEff),d2=Math.max(dist-d,dEff);
    return losHeights[i]-_frMid2*Math.sin(Math.PI*d1/(d1+d2));
  });
  var fresnelTop3=distances.map(function(d,i){
    var dEff=dist/(distances.length-1);
    var d1=Math.max(d,dEff),d2=Math.max(dist-d,dEff);
    return losHeights[i]+_frMid3*Math.sin(Math.PI*d1/(d1+d2));
  });
  var fresnelBot3=distances.map(function(d,i){
    var dEff=dist/(distances.length-1);
    var d1=Math.max(d,dEff),d2=Math.max(dist-d,dEff);
    return losHeights[i]-_frMid3*Math.sin(Math.PI*d1/(d1+d2));
  });
  // Marge adaptatiu: SRTM 90m te error +-10m en distancies curtes
  var srtmMargin=dist<500?1:dist<1000?1:1;
  var firstObstruction=-1;
  for(var i=0;i<heights.length;i++){
    if(heights[i]>losHeights[i]+srtmMargin){firstObstruction=i;break;}
  }
  document.getElementById('elev-panel').style.display='block';
  if(typeof closeAllNasaPanels==='function') closeAllNasaPanels();
  var _rfl=document.getElementById('rf-legend');if(_rfl)_rfl.style.visibility='hidden';
  // Restaura spans originals (poden haver estat sobreescrits pel 3D)
  var _ia=document.getElementById('elev-info-a');
  var _ib=document.getElementById('elev-info-b');
  if(_ia)_ia.innerHTML='<span style="color:#5b9bd5 !important">Origen A:</span> <span id="elev-a-coords" style="color:#fff !important">—</span> <span style="color:#555 !important">|</span> <span style="color:#5b9bd5 !important">Elev:</span> <span id="elev-a-val" style="color:#fff !important">—</span>';
  if(_ib)_ib.innerHTML='<span style="color:#5b9bd5 !important">Destí B:</span> <span id="elev-b-coords" style="color:#fff !important">—</span> <span style="color:#555 !important">|</span> <span style="color:#5b9bd5 !important">Elev:</span> <span id="elev-b-val" style="color:#fff !important">—</span>';
  var _irf=document.getElementById('elev-info-rf');
  if(_irf)_irf.innerHTML='<span style="color:#ff9800 !important">RF:</span> <span id="elev-rf-freq" style="color:#fff !important">—</span> <span style="color:#555 !important">|</span> <span style="color:#ff9800 !important">Dist:</span> <span id="elev-rf-dist" style="color:#fff !important">—</span> <span style="color:#555 !important">|</span> <span style="color:#ff9800 !important">FSPL:</span> <span id="elev-rf-fspl" style="color:#fff !important">—</span> <span style="color:#555 !important">|</span> <span style="color:#ff9800 !important">Refrac:</span> <span id="elev-rf-refrac" style="color:#fff !important">0.25</span>';
  var fspl=calcFSPL(dist,elevFreq);
  function setSpan(id,val){var el=document.getElementById(id);if(el)el.textContent=val;}
  setSpan('elev-a-coords',latA.toFixed(5)+', '+lngA.toFixed(5));
  setSpan('elev-a-val',bh[0]>2?eAreal.toFixed(1)+'m ('+eA.toFixed(0)+'m sol + '+bh[0].toFixed(0)+'m estructura)':eAreal.toFixed(1)+'m');
  setSpan('elev-b-coords',latB.toFixed(5)+', '+lngB.toFixed(5));
  setSpan('elev-b-val',bh[1]>2?eBreal.toFixed(1)+'m ('+eB.toFixed(0)+'m sol + '+bh[1].toFixed(0)+'m estructura)':eBreal.toFixed(1)+'m');
  setSpan('elev-rf-freq',elevFreq+'MHz');
  setSpan('elev-rf-dist',(dist/1000).toFixed(2)+'km');
  setSpan('elev-rf-fspl',fspl.toFixed(1)+'dB');
  document.getElementById('los-hint').textContent=firstObstruction>=0?'🔴 OBSTRUÏDA — Obstrucció a '+(distances[firstObstruction]/1000).toFixed(2)+'km':'🟢 LLIURE — Visió directa OK';
  if(window.elevChart2D){window.elevChart2D.destroy();window.elevChart2D=null;}
  // Ajustar escala Y per mostrar el terreny correctament
  var minH=Math.min.apply(null,heights.concat([eAreal,eBreal]).concat(fresnelBot3));
  var maxH=Math.max.apply(null,heights.concat([eAreal,eBreal]).concat(fresnelTop3));
  var pad=(maxH-minH)*0.15||10;
  window._elevYMin=Math.max(0,minH-pad);
  window._elevYMax=maxH+pad;
  renderElevPanel({
    distances:distances,heights:heights,
    losHeights:losHeights,firstObstruction:firstObstruction,
    fresnelTop:fresnelTop,fresnelBot:fresnelBot,
    fresnelTop2:fresnelTop2,fresnelBot2:fresnelBot2,
    fresnelTop3:fresnelTop3,fresnelBot3:fresnelBot3,
    bldH:bh,eAreal:eAreal,eBreal:eBreal
  });
  window.elevChart2D=elevChart;
}

