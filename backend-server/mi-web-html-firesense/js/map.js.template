// Restaurar cursor si click fora del mapa sense haver posat punt
document.addEventListener('click', function(ev){
  if(!waitingForClick) return;
  // Ignorar clicks als botons del menú LOS/RF
  if(ev.target.closest('#los-dots-wrap')||ev.target.closest('#rf-dots-wrap')||ev.target.closest('#hmenu-panel')||ev.target.closest('#rf-panel')) return;
  var mapEl = document.querySelector('.map-wrap');
  var cesEl = document.getElementById('cesium-map');
  if(mapEl && mapEl.contains(ev.target)) return;
  if(cesEl && cesEl.contains(ev.target)) return;
  waitingForClick = false;
  document.body.classList.remove('waiting-click');document.documentElement.style.cursor='';
  if(typeof map!=='undefined'&&map){
    map.getContainer().style.cursor='';
    map.getContainer().classList.remove('waiting-click');
  }
