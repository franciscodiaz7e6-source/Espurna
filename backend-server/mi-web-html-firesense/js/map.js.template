function hmSetMap(mode){
  var cp=document.getElementById("coords-panel");if(cp)cp.remove();
  ["firms-panel","ndvi-panel","power-panel","eonet-panel","burned-panel","aq-panel","aemet-panel"].forEach(function(id){var el=document.getElementById(id);if(el)el.style.display="none";});
  // Guardar i restaurar botons actius i panels al canviar de mapa
  // Guardar estat ABANS de tancar res
  var _activeIds=[];
  document.querySelectorAll(".hm-btn.active").forEach(function(b){if(b.id)_activeIds.push(b.id);});
  var _panelIds=["elev-panel","firms-panel","ndvi-panel","power-panel","eonet-panel","burned-panel","aq-panel","aemet-panel","wind-legend"];
  var _pnw=document.getElementById("pn-dots-wrap");if(_pnw&&!pnMode)_pnw.style.display="none";
  var _pnp=document.getElementById("pn-panel");if(_pnp&&!pnMode)_pnp.style.display="none";
