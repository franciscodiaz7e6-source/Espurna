/*
 * Lectura del sensor BME680 con ESP32
 * Muestra temperatura, humedad, presión y resistencia del gas por el puerto serie
 * 
 * Conexiones I2C:
 * ESP32 SDA -> BME680 SDA
 * ESP32 SCL -> BME680 SCL
 * ESP32 3.3V -> BME680 VCC
 * ESP32 GND -> BME680 GND
 * 
 * Librería requerida: Adafruit BME680 Library
 * (Instalar también: Adafruit Unified Sensor)
 */

#include <Wire.h>
#include <Adafruit_Sensor.h>
#include "Adafruit_BME680.h"

// Definir pines I2C del ESP32 (puedes cambiarlos según tu configuración)
#define SDA_PIN 21
#define SCL_PIN 22

// Dirección I2C del BME680 (puede ser 0x76 o 0x77)
#define BME_ADDRESS 0x77

Adafruit_BME680 bme; // Objeto del sensor

void setup() {
  Serial.begin(115200);
  while (!Serial);
  Serial.println("Iniciando lectura del sensor BME680...");

  // Inicializar I2C con los pines del ESP32
  Wire.begin(SDA_PIN, SCL_PIN);

  // Intentar inicializar el sensor
  if (!bme.begin(BME_ADDRESS)) {
    Serial.println("Error: No se pudo encontrar el sensor BME680");
    Serial.println("Verifica las conexiones y la dirección I2C");
    while (1); // Detener el programa
  }

  Serial.println("¡Sensor BME680 detectado correctamente!");

  // Configurar los parámetros del sensor
  bme.setTemperatureOversampling(BME680_OS_8X);
  bme.setHumidityOversampling(BME680_OS_2X);
  bme.setPressureOversampling(BME680_OS_4X);
  bme.setIIRFilterSize(BME680_FILTER_SIZE_3);
  bme.setGasHeater(320, 150); // 320°C por 150 ms

  Serial.println("Configuración completada\n");
  delay(2000);
}

void loop() {
  // Realizar la lectura del sensor
  if (!bme.performReading()) {
    Serial.println("Error al leer el sensor");
    delay(2000);
    return;
  }

  // Mostrar los datos por el puerto serie
  Serial.println("==================== LECTURA BME680 ====================");
  
  Serial.print("Temperatura:     ");
  Serial.print(bme.temperature);
  Serial.println(" °C");
  
  Serial.print("Humedad:         ");
  Serial.print(bme.humidity);
  Serial.println(" %");
  
  Serial.print("Presión:         ");
  Serial.print(bme.pressure / 100.0);
  Serial.println(" hPa");
  
  Serial.print("Altitud aprox.:  ");
  Serial.print(bme.readAltitude(1013.25)); // Presión al nivel del mar estándar
  Serial.println(" m");
  
  Serial.print("Resistencia gas: ");
  Serial.print(bme.gas_resistance / 1000.0);
  Serial.println(" KOhms");
  
  Serial.println("========================================================\n");
  
  // Esperar 2 segundos antes de la siguiente lectura
  delay(2000);
}